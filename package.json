  },
  "keywords": [],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^10.6.0",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "globals": "^17.7.0",
    "obsidian": "latest",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0"
  }
}
