{
  "name": "obsidian-mobile-tab-bar",
  "version": "1.0.1",
  "description": "Browser-style tab bar for switching between open notes on Obsidian mobile.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
